FROM node:22-alpine AS build

ARG FRONTEND_REPO=https://github.com/vanyatemno/se-school-2026-frontend.git
ARG FRONTEND_REF=main
ARG VITE_API_URL
ARG VITE_API_KEY

RUN apk add --no-cache git
WORKDIR /app

RUN git clone --depth 1 --branch ${FRONTEND_REF} ${FRONTEND_REPO} .
RUN npm ci
RUN VITE_API_URL=${VITE_API_URL} VITE_API_KEY=${VITE_API_KEY} npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html

# Single-page app config: nginx listens on 4173 and falls back to
# index.html so client-side routes (/confirm/:token, /unsubscribe/:token,
# /subscriptions) work on direct navigation.
RUN printf 'server {\n  listen 4173;\n  root /usr/share/nginx/html;\n  index index.html;\n  location / { try_files $uri /index.html; }\n}\n' \
    > /etc/nginx/conf.d/default.conf

EXPOSE 4173
